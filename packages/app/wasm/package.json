{
  "name": "@opendaw/app-wasm",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "wasm": "sh ./build-wasm.sh",
    "predev": "npm run wasm",
    "dev": "vite --host",
    "prebuild": "npm run wasm",
    "build": "vite build",
    "preview": "vite preview --host",
    "test:rust": ". \"$HOME/.cargo/env\" && cargo test --manifest-path ../../../crates/Cargo.toml --workspace",
    "pretest:parity": "npm run wasm",
    "test:parity": "vitest run --config vitest.config.ts",
    "pretest:sync": "npm run wasm",
    "test:sync": "vitest run --config vitest.config.ts test/sync.test.ts",
    "test": "npm run test:rust && npm run test:parity",
    "clean": "rm -rf dist public/*.wasm"
  },
  "dependencies": {
    "@opendaw/lib-std": "^0.0.78",
    "@opendaw/lib-dom": "^0.0.83",
    "@opendaw/lib-dsp": "^0.0.84",
    "@opendaw/lib-jsx": "^0.0.83",
    "@opendaw/studio-enums": "^0.0.77",
    "jszip": "^3.10.1",
    "soundfont2": "^0.5.0"
  },
  "devDependencies": {
    "@opendaw/lib-box": "^0.0.86",
    "@opendaw/lib-runtime": "^0.0.79",
    "@opendaw/studio-boxes": "^0.0.94",
    "@opendaw/studio-adapters": "^0.0.116",
    "sass": "^1.77.0",
    "vite": "^7.0.2",
    "vitest": "^3.1.3"
  }
}
