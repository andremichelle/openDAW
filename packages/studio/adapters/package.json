{
  "name": "@opendaw/studio-adapters",
  "version": "0.1.3",
  "license": "LGPL-3.0-or-later",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "generate-exports": "node generate-exports.mjs",
    "build": "npm run generate-exports && tsc",
    "lint": "eslint \"**/*.ts\"",
    "test": "echo \"No tests to run\"",
    "generate-all-boxes": "npx tsx scripts/generate-all-boxes.ts",
    "pregenerate-all-boxes": "npm run build -w @opendaw/studio-forge-boxes && npm run build -w @opendaw/studio-boxes"
  },
  "dependencies": {
    "@opendaw/lib-box": "^0.0.90",
    "@opendaw/lib-dsp": "^0.0.88",
    "@opendaw/lib-fusion": "^0.0.99",
    "@opendaw/lib-midi": "^0.0.70",
    "@opendaw/lib-runtime": "^0.0.83",
    "@opendaw/lib-std": "^0.0.82",
    "@opendaw/studio-boxes": "^0.0.101",
    "@opendaw/studio-enums": "^0.0.83",
    "soundfont2": "^0.5.0"
  },
  "devDependencies": {
    "@opendaw/eslint-config": "^0.0.28",
    "@opendaw/typescript-config": "^0.0.32"
  },
  "gitHead": "e4f70170c5947610932306da94e7f0bb817e43b3"
}
